# ──────────────────────────────────────────────────────────────────────
# GreenMind – Environment Configuration
# ──────────────────────────────────────────────────────────────────────
# Copy this file to .env before running docker compose.
# NEVER commit .env with real credentials.
# ──────────────────────────────────────────────────────────────────────

# ─── Database ────────────────────────────────────────────────────────
POSTGRES_USER=greenmind
POSTGRES_PASSWORD=change-this-strong-db-password
POSTGRES_DB=greenminddb
POSTGRES_PORT=5432

# ─── Service Ports ───────────────────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ─── CORS ────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:3000

# ─── JWT Authentication ─────────────────────────────────────────────
# Must be at least 32 characters. Generate with:
#   openssl rand -hex 32
JWT_SECRET_KEY=replace-this-with-a-long-random-secret-at-least-32-chars
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ─── Local Data Storage (macOS iCloud fix) ───────────────────────────
# If your project is in an iCloud-synced folder, set these to a path
# OUTSIDE of iCloud to prevent database corruption.
# LOCAL_DATA_ROOT=/Users/yourname/LocalData/greenmind
# PGDATA_DIR=/Users/yourname/LocalData/greenmind/postgres_data

# ─── Resend / E-Mail ────────────────────────────────────────────────
RESEND_API_KEY=re_123456789
EMAIL_FROM=onboarding@biolingo.org
FRONTEND_URL=https://biolingo.org
CONTACT_FORM_TO=team@yourdomain.com

# ─── Logging ─────────────────────────────────────────────────────────
# LOG_LEVEL=INFO
