# GreenMind Backend — Environment Variables
# Copy this file to .env and fill in real values.

# ── Database ─────────────────────────────────
POSTGRES_USER=plantuser
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=plantdb
POSTGRES_PORT=5432
PGDATA_DIR=./postgres_data

# ── Backend ──────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
JWT_SECRET_KEY=CHANGE_ME_AT_LEAST_32_CHARACTERS_LONG
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080
COOKIE_DOMAIN=
COOKIE_SECURE=false

# ── CORS ─────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ── Email (Resend) ───────────────────────────
RESEND_API_KEY=
EMAIL_FROM=onboarding@yourdomain.com
FRONTEND_URL=http://localhost:3000
CONTACT_FORM_TO=hello@yourdomain.com

# ── S3 / MinIO ───────────────────────────────
S3_ENDPOINT=http://minio:9000
S3_REGION=eu-central-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=CHANGE_ME_MINIO_ROOT_PASSWORD

# ── Ports ────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=3000
