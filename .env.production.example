# GreenMind — Production Environment Variables
# Copy to /opt/greenmind-prod/.env and fill in real values.

# ── Database ─────────────────────────────────
POSTGRES_USER=admin
POSTGRES_PASSWORD=CHANGE_ME_PRODUCTION
POSTGRES_DB=plantdb
POSTGRES_PORT=5432

# ── Backend ──────────────────────────────────
ENVIRONMENT=production
JWT_SECRET_KEY=CHANGE_ME_AT_LEAST_32_CHARACTERS_LONG_PRODUCTION
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080
COOKIE_DOMAIN=green-mind.ch
COOKIE_SECURE=true

# ── CORS ─────────────────────────────────────
CORS_ORIGINS=https://green-mind.ch,https://www.green-mind.ch,https://greenmind.biolingo.org

# ── Email (Resend) ───────────────────────────
RESEND_API_KEY=
EMAIL_FROM=onboarding@green-mind.ch
FRONTEND_URL=https://green-mind.ch
CONTACT_FORM_TO=

# ── S3 / MinIO (REQUIRED – no defaults!) ─────
MINIO_ROOT_USER=CHANGE_ME_MINIO_USER
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD

# ── Ports ────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=3000
