# GreenMind — Staging Environment Variables
# Copy to /opt/greenmind-staging/.env and fill in real values.

# ── Database ─────────────────────────────────
POSTGRES_USER=plantuser
POSTGRES_PASSWORD=CHANGE_ME_STAGING
POSTGRES_DB=plantdb_staging
POSTGRES_PORT=5433

# ── Backend ──────────────────────────────────
ENVIRONMENT=staging
JWT_SECRET_KEY=CHANGE_ME_AT_LEAST_32_CHARACTERS_LONG_STAGING
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080
COOKIE_DOMAIN=test.green-mind.ch
COOKIE_SECURE=true

# ── CORS ─────────────────────────────────────
CORS_ORIGINS=https://test.green-mind.ch

# ── Email (Resend) ───────────────────────────
RESEND_API_KEY=
EMAIL_FROM=noreply@green-mind.ch
FRONTEND_URL=https://test.green-mind.ch
CONTACT_FORM_TO=

# ── S3 / MinIO ───────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_STAGING
MINIO_PORT=9002
MINIO_CONSOLE_PORT=9003

# ── Ports ────────────────────────────────────
BACKEND_PORT=8001
FRONTEND_PORT=3001

# ASPSMS (Electrode Alerts)
ASPSMS_USERKEY=staging_userkey_hier
ASPSMS_PASSWORD=staging_passwort_hier
ASPSMS_SENDER_ID=GreenMind
